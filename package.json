{
  "name": "novel-grab",
  "version": "1.0.0",
  "description": "NovelGrab Desktop App",
  "main": "main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite build && electron .",
    "pack:mac": "vite build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.0",
    "antd": "^5.23.0",
    "axios": "^1.7.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.15.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.novelgrab.desktop",
    "productName": "NovelGrab",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "NovelGrabServer",
        "to": "NovelGrabServer"
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": "AppImage"
    }
  }
}
